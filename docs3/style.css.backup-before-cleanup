/* Timer Styles */
.timer-section {
    margin: 30px auto 0 auto;
}

.timer-box {
    padding: 16px;
    margin: 0 auto;
    max-width: 100%;
    overflow-x: auto;
}

.timers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    grid-auto-rows: 1fr;
    gap: 20px;
    margin-bottom: 12px;
    height: 100%;
    padding: 5px;
    flex: 1;
    justify-items: stretch;
    align-items: stretch;
    align-content: start;
    position: relative;
    max-width: 100%;
    width: 100%;
    box-sizing: border-box;
    min-height: 0;
}

/* Usar espacio disponible hasta máximo 4 columnas */
@media (min-width: 1200px) {
    .timers-grid {
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        max-width: 1600px;
        margin: 20px auto;
    }
}

/* Single timer - extra large */
.timers-grid:has(.timer-card:only-of-type) {
    grid-template-columns: 1fr;
    max-width: 800px;
    margin: 20px auto;
}

.timers-grid:has(.timer-card:only-of-type) .timer-card {
    padding: 20px;
    max-width: 800px;
    margin: 0 auto;
}

.timers-grid:has(.timer-card:only-of-type) .time-display {
    font-size: 6em;
}

.timers-grid:has(.timer-card:only-of-type) .timer-controls {
    gap: 20px;
    margin: 30px 0;
}

.timers-grid:has(.timer-card:only-of-type) .timer-btn {
    padding: 16px 32px;
    font-size: 18px;
}

.timers-grid:has(.timer-card:only-of-type) .timer-name {
    padding: 12px 16px;
    font-size: 20px;
}

/* Multiple timers - grid layout usando espacio disponible */
.timers-grid:not(:has(.timer-card:only-of-type)) {
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    max-width: 1600px;
    margin: 20px auto;
    width: 100%;
}

/* Usar espacio disponible hasta máximo 4 columnas */
@media (min-width: 1200px) {
    .timers-grid:not(:has(.timer-card:only-of-type)) {
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        max-width: 1600px;
        width: 100%;
    }
    
    .timers-grid.multiple-timers {
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        max-width: 1600px;
        width: 100%;
    }
}

/* Medium screens - usar espacio disponible */
@media (min-width: 900px) and (max-width: 1199px) {
    .timers-grid:not(:has(.timer-card:only-of-type)) {
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        max-width: 1200px;
    }
    
    .timers-grid.multiple-timers {
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        max-width: 1200px;
    }
}

/* Small screens - usar espacio disponible */
@media (min-width: 600px) and (max-width: 899px) {
    .timers-grid:not(:has(.timer-card:only-of-type)) {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        max-width: 900px;
    }
    
    .timers-grid.multiple-timers {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        max-width: 900px;
    }
    
    .timers-grid.single-timer .time-display {
        font-size: 4em;
    }
    
    .timers-grid.single-timer .timer-card {
        padding: 30px;
        max-width: 600px;
    }
}

