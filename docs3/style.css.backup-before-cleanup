}

.timer-card.paused {
    background: rgba(243, 156, 18, 0.05);
}

.timer-card.paused .time-display {
    color: #f39c12;
}

.timer-card.finished {
    background: rgba(231, 76, 60, 0.05);
    animation: pulse 1s infinite;
}

.timer-card.finished .time-display {
    color: #e74c3c;
}

@keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
}

